rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // Single getUserRole() call shared by all role checks
    // to avoid stacking get() reads that trigger
    // permission denials under rapid consecutive writes.
    // ════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isStaff() {
      return getUserRole() == 'staff';
    }

    function isAdminOrStaff() {
      let role = getUserRole();
      return role == 'admin' || role == 'staff';
    }

    function isParent() {
      return getUserRole() == 'parent';
    }

    // Check if the requesting user is the parent who owns a doc
    function isOwningParent(parentId) {
      return isAuthenticated() && request.auth.uid == parentId;
    }


    // ════════════════════════════════════════════════════
    // USERS
    // ════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
                       request.resource.data.role == 'staff';

      allow update: if isAuthenticated() &&
                       (request.auth.uid == userId || isAdmin());

      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // PARENTS
    // Parents can read/write their own doc.
    // Admin & staff can read/write all.
    // ════════════════════════════════════════════════════
    match /parents/{parentId} {
      allow read:   if isAdminOrStaff() || isOwningParent(parentId) || (isAuthenticated() && request.auth.uid in resource.data.children);
      allow create: if isAdminOrStaff() || isAuthenticated();
      allow update: if isAdminOrStaff() || isOwningParent(parentId);
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // STUDENTS  (role-based, linked to parent + subjects)
    // ════════════════════════════════════════════════════
    match /students/{studentId} {
      // Admin/staff full access. Students read their own. Parents can read their children's records.
      allow read: if isAdminOrStaff() ||
                 (isAuthenticated() && request.auth.uid == resource.data.uid) ||
                 (isAuthenticated() && isParent() && resource.data.parentId == request.auth.uid);
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // TUTORS
    // ════════════════════════════════════════════════════
    match /tutors/{tutorId} {
      allow read:         if true;
      allow write, delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // STUDENT REQUESTS
    // Public can create (registration form).
    // Only admin/staff can read and update status.
    // ════════════════════════════════════════════════════
    match /student_requests/{reqId} {
      allow create: if true;   // public registration form
      allow read:   if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // TUTOR APPLICATIONS
    // Public can create (Apply as Tutor form).
    // Only admin can read and update.
    // ════════════════════════════════════════════════════
    match /tutor_applications/{appId} {
      allow create: if true;   // public tutor application form
      allow read:   if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // ENROLLMENT REQUESTS
    // Parents create. Admin/staff read and approve.
    // ════════════════════════════════════════════════════
    match /enrollment_requests/{enrId} {
      // Authenticated parents can create
      allow create: if isParent();

      // Admin/staff can read all; parents can read their own
      allow read: if isAdminOrStaff() ||
                     (isAuthenticated() &&
                      resource.data.parentId == request.auth.uid);

      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // PAYMENTS
    // Admin/staff full access. Parents read their own.
    // ════════════════════════════════════════════════════
    match /payments/{paymentId} {
      allow read: if isAdminOrStaff() ||
                     (isAuthenticated() &&
                      resource.data.parentId == request.auth.uid);
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // SESSIONS
    // ════════════════════════════════════════════════════
    match /sessions/{sessionId} {
      allow read: if isAdminOrStaff() ||
                     (isAuthenticated() && (
                       resource.data.studentId == request.auth.uid ||
                       resource.data.tutorId   == request.auth.uid
                     ));
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // PENDING STAFF (staff creation workflow)
    // ════════════════════════════════════════════════════
    match /pendingStaff/{staffId} {
      allow read, write, delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // SCHOOL ACCESS CODES
    // ════════════════════════════════════════════════════
    match /schools/{schoolId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // SCHOOL EXAMS
    // ════════════════════════════════════════════════════
    match /schoolExams/{examId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // SCHOOL RESOURCES
    // ════════════════════════════════════════════════════
    match /schoolResources/{resourceId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // SCHOOL LINKS
    // ════════════════════════════════════════════════════
    match /schoolLinks/{linkId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // INDIVIDUAL STUDENTS (private portal students)
    // ════════════════════════════════════════════════════
    match /individualStudents/{studentId} {
      allow read: if isAdminOrStaff() || request.auth.uid == studentId;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // PERSONAL RESOURCES (student-specific)
    // ════════════════════════════════════════════════════
    match /personalResources/{docId} {
      allow read: if isAdminOrStaff() || request.auth.uid == resource.data.studentId;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // PERSONAL LINKS (student-specific)
    // ════════════════════════════════════════════════════
    match /personalLinks/{docId} {
      allow read: if isAdminOrStaff() || request.auth.uid == resource.data.studentId;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // GENERAL RESOURCES
    // ════════════════════════════════════════════════════
    match /resources/{resourceId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // GENERAL LINKS
    // ════════════════════════════════════════════════════
    match /links/{linkId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // GENERAL EXAMS
    // ════════════════════════════════════════════════════
    match /exams/{examId} {
      allow read:          if true;
      allow write, delete: if isAdminOrStaff();
    }


    // ════════════════════════════════════════════════════
    // STAFF GENERAL RESOURCES
    // ════════════════════════════════════════════════════
    match /staffGeneralResources/{resourceId} {
      allow read:          if isAdminOrStaff();
      allow write, delete: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // STAFF SCHOOL ACCESS
    // ════════════════════════════════════════════════════
    match /staffSchoolAccess/{docId} {
      allow read:  if isAdminOrStaff();
      allow write: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // STAFF REGISTRATION CODE
    // ════════════════════════════════════════════════════
    match /staffRegistration/{docId} {
      allow read:  if isAdmin() || !isAuthenticated();  // staff need to read code during signup, but only when not logged in
      allow write: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // NOTIFICATIONS
    // Admin writes. Anyone can read (public portal).
    // Authenticated users can mark own as read.
    // ════════════════════════════════════════════════════
    match /notifications/{notificationId} {
      allow read: if isAdmin() ||
                 (isAuthenticated() &&
                  (resource.data.recipientId == request.auth.uid ||
                   resource.data.recipientId == 'all' ||
                   resource.data.recipientId == 'all_students'));
      allow create: if isAdmin();
      allow delete: if isAdmin();

      // Admin can update any field; authenticated users can only
      // flip the `read` field on notifications addressed to them.
      allow update: if isAdmin() ||
                       (isAuthenticated() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                        (resource.data.recipientId == request.auth.uid ||
                         resource.data.recipientId == 'all' ||
                         resource.data.recipientId == 'all_students'));
    }


    // ════════════════════════════════════════════════════
    // NEWS CORNER (PUBLIC)
    // ════════════════════════════════════════════════════
    match /newsCorner/{newsId} {
      allow read:   if true;

      allow create: if isAdmin();
      allow delete: if isAdmin();

      // Admin can update any fields (evaluated first)
      allow update: if isAdmin();

      // Public can ONLY increment the views counter
      allow update: if !isAuthenticated() &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                       request.resource.data.views == resource.data.views + 1;
    }


    // ════════════════════════════════════════════════════
    // CONTACT MESSAGES
    // Public can create (contact form on landing page).
    // Only admin can read.
    // ════════════════════════════════════════════════════
    match /contact_messages/{msgId} {
      allow create: if true;     // public contact form
      allow read:   if isAdmin();
      allow delete: if isAdmin();
      // Allow admin to mark as read
      allow update: if isAdmin();
    }


    // ════════════════════════════════════════════════════
    // ACTIVITY LOGS
    // ════════════════════════════════════════════════════
    match /activityLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if isAuthenticated();
    }


    // ════════════════════════════════════════════════════
    // DEFAULT DENY
    // ════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
